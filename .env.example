# ─── SERVER ───
PORT=3000
NODE_ENV=development

# ─── DATABASE ───
MONGODB_URI=mongodb://localhost:27017/mahattaart

# ─── AUTH ───
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# ─── FILE UPLOADS ───
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760       # 10 MB in bytes

# ─── CORS ───
# Comma-separated list of allowed origins (leave blank to allow all — dev only)
ALLOWED_ORIGINS=http://localhost:3001,https://admin.mahattaart.com

# ─── SEED SCRIPT (npm run seed) ───
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@mahattaart.com
ADMIN_PASS=Admin@1234
VIKAS_PASS=Vikas@1234

# ─── SELLER DETAILS (used in GST invoice generation) ───
SELLER_GST=07AABCM1234A1Z5
SELLER_STATE=Delhi

# ─── EMAIL (Task Manager Notifications) ───
# Use Gmail SMTP example (create an App Password in Google Account settings):
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="MahattaART Tasks <your-email@gmail.com>"
# Emails are silently skipped if these vars are not set

# ─── AI (OpenAI) ───
# Get a key from https://platform.openai.com/api-keys
# AI features are silently disabled if this is not set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
